from glob import glob
configfile: 'config/config.yaml'

include: 'lib/config.smk'
include: 'rules/metadata.smk'
include: 'rules/minimap2.smk'
include: 'rules/impg.smk'
include: 'rules/bedtools.smk'
include: 'rules/samtools.smk'
include: 'rules/kfilt.smk'
include: 'rules/pggb.smk'
include: 'rules/odgi.smk'
include: 'rules/pangene.smk'
include: 'rules/bwa-mem2.smk'
include: 'rules/bwa.smk'
include: 'rules/minimap2_reads.smk'
include: 'rules/gfainject.smk'
include: 'rules/gafpack.smk'
include: 'rules/cosigt.smk'
include: 'rules/benchmark.smk'
include: 'rules/refine.smk'
include: 'rules/wally.smk'

cosigt_input    = set()
refine_input    = set()
cosigt_benchmark= set()

wally_viz = config.get('wally_viz', False)
svbyeye_viz = config.get('svbyeye_viz', False)
sv_calling = config.get('sv_calling', False)
odgi_viz = config.get('odgi_viz', True)
pangene_viz = config.get('pangene_viz', True)
vcf_output = config.get('vcf', False)
has_gene_annotations = config.get('gtf', 'NA') != 'NA' and config.get('proteins', 'NA') != 'NA'

for region in config['regions']:
    chrom = '_'.join(region.split('_')[:-2])   # robust: coords are always the last 2 blocks
    for sample in config['samples']:
        cosigt_input.add(
            outpath("cosigt", sample, chrom, region, f"{region}.cosigt_genotype.tsv")
        )
        if wally_viz:
            cosigt_input.add(outpath("wally", sample, chrom, region, "wally.done"))
            cosigt_benchmark.add(outpath("wally", sample, chrom, region, "wally.done"))
        if svbyeye_viz:
            cosigt_input.add(outpath("cosigt", sample, chrom, region, "viz", f"{region}.ava.png"))
            cosigt_benchmark.add(outpath("cosigt", sample, chrom, region, "viz", f"{region}.ava.png"))
        # optional per-sample SV calling with svim-asm
        if sv_calling:
            cosigt_input.add(
                outpath("cosigt", sample, chrom, region, "svim_asm", "variants.vcf")
            )
    if odgi_viz:
        cosigt_input.add(outpath("odgi", "viz", chrom, region, f"{region}.viz.png"))
        cosigt_benchmark.add(outpath("odgi", "viz", chrom, region, f"{region}.viz.png"))
    if ALLELE_SOURCE == 'assemblies':
        refine_input.add(outpath("refine", "regions_refined.bed"))
    if has_gene_annotations and pangene_viz:
        cosigt_input.add(outpath("pangene", "viz", chrom, region, f"{region}.genes.png"))
        cosigt_benchmark.add(outpath("pangene", "viz", chrom, region, f"{region}.genes.png"))
    cosigt_benchmark.add(outpath("benchmark", "tpr.qv_bar.png"))

# optional multi-sample, multi-region merged VCF from cosigt genotypes
if vcf_output:
    cosigt_input.add(outpath("cosigt", "vcf", "cosigt.vcf.gz"))

# USED TO REFINE INPUT REGIONS
rule refine:
    input:
        list(refine_input)

localrules: check, write_all_regions, write_flagger_blacklist, write_region_bed

# FAST CONFIG AND INPUT VALIDATION
rule check:
    input:
        METADATA_TARGETS

# COSIGT COMMAND
rule cosigt:
    input:
        list(cosigt_input)

# USED ONLY FOR BENCHMARKING - DO NOT USE OTHERWISE
rule benchmark:
    input:
        list(cosigt_benchmark)
